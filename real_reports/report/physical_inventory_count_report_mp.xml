<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <template id="report_physical_inventory_count_mp">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    /* Estilos para que el encabezado se mantenga arriba */
                    .header {
                    margin-bottom: 30px;
                    }
                    .table-custom {
                    width: 100%;
                    border-collapse: collapse !important;
                    table-layout: fixed;
                    border: 1px solid black !important;
                    margin-bottom: 20px;
                    page-break-inside: auto; /* Permite que la tabla se rompa elegantemente */
                    }
                    .table-custom tr {
                    page-break-inside: avoid;
                    page-break-after: auto;
                    }
                    .table-custom th, .table-custom td {
                    border: 1px solid black !important;
                    padding: 4px;
                    word-wrap: break-word;
                    }
                    .header-table {
                    width: 100%;
                    border: 1px solid black !important;
                    border-collapse: collapse;
                    }
                    .header-table td {
                    border: 1px solid black !important;
                    }
                    .obs-line {
                    height: 30px;
                    border-bottom: 1px solid #ccc;
                    margin: 0 10px;
                    }
                </style>

                <div class="page">
                    <div class="header">
                        <table class="table table-bordered header-table">
                            <tr>
                                <td rowspan="3" class="text-center align-middle" style="width: 60%;">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <img
                                            t-if="res_company.logo"
                                            t-att-src="image_data_uri(res_company.logo)"
                                            style="max-height: 50px;"
                                            class="me-3"
                                        />
                                        <div>
                                            <strong>
                                                <t t-esc="res_company.name" />
                                            </strong>
                                            <br />
                                            <strong style="font-size: 10px;">Conteo Físico de
                                                Inventarios</strong>
                                        </div>
                                    </div>
                                </td>
                                <td colspan="2" class="text-center bg-light" style="font-size: 13px;">
                                    <strong>FORMATO</strong>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-center" style="font-size: 13px;">
                                    <strong>Código:</strong>
                                    <span> P-029 </span>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-center" style="width: 20%; font-size: 13px;">
                                    <strong>Revisión:</strong>
                                    <span>28/08/2024</span>
                                </td>
                                <td class="text-center" style="width: 20%; font-size: 13px;">
                                    <strong>Pág:</strong>
                                    <span class="page" />
                                    <span>de </span>
                                    <span class="topage" />
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div class="row mt-3 mb-3">
                        <div class="col-6 text-center">
                            <strong>Persona que realizó el conteo:</strong>
                            <span>_____________________________________</span>
                        </div>
                        <div class="col-6 text-center">
                            <strong>Fecha:</strong>
                            <span t-esc="print_date" />
                        </div>
                    </div>

                    <table class="table-custom">
                        <thead>
                            <tr style="background-color: #f8f9fa; text-align: center;">
                                <th style="width: 50%;">
                                    <t t-esc="category_name" />
                                </th>
                                <!-- <th style="width: 50%;">Nombre</th> -->
                                <th style="width: 10%;">Físico</th>
                                <th style="width: 10%;">Odoo</th>
                                <th style="width: 10%;">Diferencia</th>
                                <th style="width: 20%;"># Lote mas viejo</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="line">
                                <tr>
                                    <td style="font-size: 15px;">
                                        <span t-esc="line.get('product_name')" />
                                    </td>
                                    <td />
                                    <td />
                                    <td />
                                    <td />
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <table style="width: 100%; border: none;">
                        <tr>
                            <td style="width: 60%; vertical-align: top;">
                                <div class="obs-line">
                                    <strong>OBSERVACIONES:</strong>
                                </div>
                                <div class="obs-line" />
                                <div class="obs-line" />
                                <div class="obs-line" />
                            </td>
                            <td style="width: 40%; vertical-align: bottom; text-align: center;">
                                <span>_________________________________________</span>
                                <br />
                                <strong>Firma</strong>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <record id="action_physical_inventory_count_mp" model="ir.actions.report">
        <field name="name">Physical Inventory Count MP</field>
        <field name="model">physical.inventory.count.mp</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">real_reports.report_physical_inventory_count_mp</field>
        <field name="report_file">report_physical_inventory_count_mp</field>
        <field name="binding_model_id" ref="model_physical_inventory_count_mp" />
    </record>

    <record model="ir.ui.view" id="action_physical_inventory_count_mp_selector">
        <field name="name">physical.inventory.count.mp.form</field>
        <field name="model">physical.inventory.count.mp</field>
        <field name="arch" type="xml">
            <form string="P-029">
                <sheet>
                    <div class="oe_title">
                        <h1>Conteo físico de inventarios</h1>
                    </div>

                    <group>
                        <field name="category_id" widget="selection" required="1" />
                    </group>

                </sheet>
                <footer>
                    <button string="Cerrar" class="btn-secondary" special="cancel" />
                    <button name="action_print_report" string="Print Report" type="object" class="btn-primary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_physical_inventory_count_mp_wizard" model="ir.actions.act_window">
        <field name="name">Conteo físico de inventarios</field>
        <field name="res_model">physical.inventory.count.mp</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_physical_inventory_report_mp"
        name="Physical Inventory Count MP"
        parent="quant_reports_menu"
        action="action_physical_inventory_count_mp_wizard"
        sequence="10"
    />
</odoo>
