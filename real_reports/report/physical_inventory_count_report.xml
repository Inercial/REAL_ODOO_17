<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_physical_inventory_count">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <style>
                    /* Estilos para que el encabezado se mantenga arriba */
                    .header {
                    margin-bottom: 20px;
                    }
                    .table-custom {
                    width: 100%;
                    border-collapse: collapse !important;
                    table-layout: fixed;
                    border: 1px solid black !important;
                    margin-bottom: 20px;
                    page-break-inside: auto; /* Permite que la tabla se rompa elegantemente */
                    }
                    .table-custom tr {
                    page-break-inside: avoid;
                    page-break-after: auto;
                    }
                    .table-custom th, .table-custom td {
                    border: 1px solid black !important;
                    padding: 4px;
                    word-wrap: break-word;
                    }
                    .header-table {
                    width: 100%;
                    border: 1px solid black !important;
                    border-collapse: collapse;
                    }
                    .header-table td {
                    border: 1px solid black !important;
                    }
                    .obs-line {
                    height: 30px;
                    border-bottom: 1px solid #ccc;
                    margin: 0 10px;
                    }
                </style>

                <div class="page">
                    <div class="header">
                        <table class="table table-bordered header-table">
                            <tr>
                                <td rowspan="3" class="text-center align-middle" style="width: 60%;">
                                    <div class="d-flex align-items-center justify-content-center">
                                        <img t-if="res_company.logo"
                                            t-att-src="image_data_uri(res_company.logo)"
                                            style="max-height: 50px;" class="me-3" />
                                        <div>
                                            <strong>
                                                <t t-esc="res_company.name" />
                                            </strong>
                                            <br />
                                            <strong style="font-size: 10px;">Conteo Físico de
                                                Inventarios</strong>
                                        </div>
                                    </div>
                                </td>
                                <td colspan="2" class="text-center bg-light"
                                    style="font-size: 13px;">
                                    <strong>FORMATO</strong>
                                </td>
                            </tr>
                            <tr>
                                <td colspan="2" class="text-center" style="font-size: 13px;">
                                    <strong>Código:</strong>
                                    <span> L-044 </span>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-center" style="width: 20%; font-size: 13px;">
                                    <strong>Revisión:</strong>
                                    <span>03/07/2025</span>
                                </td>
                                <td class="text-center" style="width: 20%; font-size: 13px;">
                                    <strong>Pág:</strong>
                                    <span class="page" />
                                    <span>de </span>
                                    <span class="topage" />
                                </td>
                            </tr>
                        </table>
                    </div>

                    <div class="row mt-3 mb-3">
                        <div class="col-6 text-center">
                            <strong>Persona que realizó el conteo:</strong>
                            <span>_____________________________________</span>
                        </div>
                        <div class="col-6 text-center">
                            <strong>Fecha:</strong>
                            <span t-esc="print_date" />
                        </div>
                    </div>

                    <t t-foreach="['POLVOS', 'EMULSIONES']" t-as="category">
                        <t t-set="lines"
                            t-value="[l for l in docs if l['complete_name'] == category]" />
                        <t t-if="lines">
                            <table class="table-custom">
                                <thead>
                                    <tr style="background-color: #f8f9fa; text-align: center;">
                                        <th style="width: 50%;">
                                            <t t-esc="category" />
                                        </th>
                                        <th style="width: 10%;">Físico</th>
                                        <th style="width: 10%;">Odoo</th>
                                        <th style="width: 10%;">Diferencia</th>
                                        <th style="width: 20%;"># Lote mas viejo</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="lines" t-as="line">
                                        <tr>
                                            <td style="font-size: 15px;">
                                                <span t-esc="line['product_name']" />
                                            </td>
                                            <td class="text-center" />
                                            <td style="font-size: 14px;" class="text-end">
                                                <span t-esc="line['quantity']" />
                                            </td>
                                            <td class="text-center" />
                                            <td class="text-center" />
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                    </t>
                    <table style="width: 100%; border: none;">
                        <tr>
                            <td style="width: 60%; vertical-align: top;">
                                <div class="obs-line">
                                    <strong>OBSERVACIONES:</strong>
                                </div>
                                <div class="obs-line" />
                                <div class="obs-line" />
                                <div class="obs-line" />
                            </td>
                            <td style="width: 40%; vertical-align: bottom; text-align: center;">
                                <span>_________________________________________</span>
                                <br />
                                <strong>Firma</strong>
                            </td>
                        </tr>
                    </table>
                </div>
            </t>
        </t>
    </template>

    <record id="action_physical_inventory_count" model="ir.actions.report">
        <field name="name">Physical Inventory Count</field>
        <field name="model">physical.inventory.count</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">real_reports.report_physical_inventory_count</field>
        <field name="report_file">real_reports.report_physical_inventory_count</field>
    </record>

    <menuitem
        id="menu_physical_inventory_report"
        name="Physical Inventory Count"
        parent="quant_reports_menu"
        action="action_physical_inventory_count"
        sequence="10"
    />
</odoo>