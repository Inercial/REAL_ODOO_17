<odoo>
    <record id="view_pending_tons_wizard_form" model="ir.ui.view">
        <field name="name">pending.tons.wizard.form</field>
        <field name="model">pending.tons.wizard</field>
        <field name="arch" type="xml">
            <form string="Pending Tons Report" create="false" edit="false">
                <group>
                    <!-- Datetime input -->
                    <group col="1">
                        <field name="datetime_input" />
                    </group>

                    <!-- Result line (label + value on same row) -->
                    <group col="2">
                        <label for="result_tons" string="Pending Tons" />
                        <field name="result_tons" readonly="1" nolabel="1" class="oe_inline" widget="float" />
                    </group>
                </group>

                <!-- Buttons -->
                <footer>
                    <button name="action_compute" string="Compute" type="object" class="btn-primary" />

                    <button string="Discard" special="cancel" class="btn-secondary" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_pending_tons_wizard" model="ir.actions.act_window">
        <field name="name">Pending Tons Report</field>
        <field name="res_model">pending.tons.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem
        id="menu_pending_tons_report"
        name="Pending Tons Report"
        parent="sale_reports_menu"
        action="action_pending_tons_wizard"
        sequence="30"
    />
</odoo>
