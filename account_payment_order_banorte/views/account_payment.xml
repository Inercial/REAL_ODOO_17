<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record model="ir.ui.view" id="account_payment_form_banorte">
        <field name="name">account_payment.form.banorte</field>
        <field name="model">account.payment</field>
        <field name="inherit_id" ref="account.view_account_payment_form" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_post']" position="after">
                <!--
                    Button "Generate Payment File"

                    Visible only when:
                    - Payment is posted (state == 'posted')
                    - It's an outbound payment (payment_type != 'inbound')
                    - The selected payment method supports file generation
                      (create_payment_file == True, which is a stored related field
                       coming from payment_method_id.generate_payment_file)

                    Hidden otherwise.
                -->
                <button
                    invisible="state != 'posted' or payment_type == 'inbound' or not create_payment_file"
                    name="open2generated"
                    type="object"
                    string="Generate Payment File"
                    class="oe_highlight"
                />
            </xpath>
            <xpath expr="//field[@name='payment_type']" position="after">
                <field name="state_txt" invisible="1" />
                <field name="create_payment_file" invisible="1" />
            </xpath>
            <xpath expr="//field[@name='date']" position="after">
                <field name="expiration_date" readonly="state != 'draft'" />
                <field name="ref_1" readonly="state != 'draft'" />
                <field name="ref_2" readonly="state != 'draft'" />
            </xpath>
        </field>
    </record>
</odoo>
