<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sample_report">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size: 16px; font-family: sans-serif;">
                        <table class="table table-borderless"
                            style="width: 100%; margin-bottom: 20px; border: none; font-size: 35px">
                            <tr>
                                <td style="width: 33%; border: none;" />
                                <td
                                    style="width:33 %; text-align: center; vertical-align: middle; border: none;">
                                    <span>MUESTRA</span>
                                </td>
                                <td
                                    style="width: 33%; text-align: right; vertical-align: middle; border: none; background-color: #FFFFFF">
                                    <span>L-075</span>
                                </td>
                            </tr>
                        </table>
                        <div class="container-fluid">
                            <div class="row mt-2">
                                <div class="col-4">
                                    <strong>
                                        <u>MUESTRA:</u>
                                    </strong>
                                    <br />
                                    <span t-field="o.name"
                                        style="font-size: 25px; font-weight: bold;" />
                                </div>
                                <div class="col-4">
                                    <strong>
                                        <u>ORDEN:</u>
                                    </strong>
                                    <br />
                                    <span t-field="o.origin" />
                                </div>
                                <div class="col-4">
                                    <strong>
                                        <u>ESTADO:</u>
                                    </strong>
                                    <br />
                                    <span t-field="o.state" />
                                </div>
                            </div>
                            <div class="row mt-3">
                                <div class="col-4">
                                    <strong>
                                        <u>PESO:</u>
                                    </strong>
                                    <br />
                                    <span
                                        t-esc="'{0:.2f}'.format(o.tons_display)" /> Ton. </div>
                                <div class="col-4">
                                    <strong>
                                        <u>FECHA DE VALIDACION:</u>
                                    </strong>
                                    <br />
                                    <span t-field="o.date_done" />
                                </div>
                                <div class="col-4">
                                    <strong>
                                        <u>DIRECCIÓN DE CLIENTE:</u>
                                    </strong>
                                    <div style="font-size: 15px; margin-top: 5px;">
                                        <span t-field="o.partner_id" />
                                        <div t-if="o.partner_id.phone" class="mt-1">
                                            <i class="fa fa-phone" style="margin-right: 5px;" />
                                            <span t-field="o.partner_id.phone" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <table class="table table-sm table-bordered">
                                <thead>
                                    <tr>
                                        <th>PRODUCTO</th>
                                        <th>CANTIDAD</th>
                                        <th>DESDE</th>
                                    </tr>
                                </thead>
                                <t t-foreach="o.move_line_ids_without_package" t-as="table_line">
                                    <tr>
                                        <td>
                                            <span t-field="table_line.product_id" />
                                        </td>
                                        <td>
                                            <span t-field="table_line.qty_done" />
                                            <span t-field="table_line.product_uom_id" />
                                        </td>
                                        <td>
                                            <span t-field="table_line.location_id" />
                                        </td>
                                    </tr>
                                </t>
                            </table>
                        </div>
                        <table class="table table-borderless"
                            style="width: 100%; border: none; margin-top: 50px">
                            <tr>
                                <td style="width: 60%; vertical-align: top; border: none;">
                                    <p style="font-weight: bold;">NOTAS:</p>
                                    <span t-field="o.note" />
                                </td>
                                <td
                                    style="width: 40%; vertical-align: bottom; text-align: center; background-color: #FFFFFF; border: none;">
                                    <div
                                        style="border-bottom: 1px solid black; width: 300px; margin: 50px auto 5px auto;" />
                                    <strong>FIRMA</strong>
                                </td>
                            </tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_sample_report" model="ir.actions.report">
        <field name="name">MUESTRA</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">real.sample_report</field>
        <field name="report_file">real.sample_report</field>
        <field name="binding_model_id" ref="stock.model_stock_picking" />
        <field name="binding_type">report</field>
        <field name="print_report_name">'MUESTRA - ' + object.name</field>
    </record>
</odoo>