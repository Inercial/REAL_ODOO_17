<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_delivery_remision_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page" style="font-size: 16px; font-family: sans-serif;">
                        <table class="table table-borderless"
                            style="width: 100%; margin-bottom: 20px; border: none; font-size: 35px">
                            <tr>
                                <td
                                    style="width: 33%; text-align: left; vertical-align: middle; border: none;">
                                    <span t-field="o.name" />
                                </td>
                                <td
                                    style="width: 33%; text-align: center; vertical-align: middle; border: none;">
                                    <span>
                                        REMISIÓN</span>
                                </td>
                                <td
                                    style="width: 33%; text-align: right; vertical-align: middle; border: none; background-color: #FFFFFF">
                                    <span>L-005</span>
                                </td>
                            </tr>
                        </table>
                        <div class="container-fluid">
                            <div class="row mt-2">
                                <div class="col-4">
                                    <strong>
                                        <u>FOLIO PEDIDO:</u>
                                    </strong>
                                    <br />
                                    <span t-field="o.origin" />
                                </div>
                                <div class="col-4">
                                    <strong>
                                        <u>CLIENTE:</u>
                                    </strong>
                                    <br />
                                    <span t-field="o.partner_id" />
                                </div>
                                <div class="col-4">
                                    <strong>
                                        <u>FECHA:</u>
                                    </strong>
                                    <br />
                                    <span t-field="o.date_done" t-options='{"widget": "date"}' />
                                </div>
                            </div>
                            <div class="row mt-3">
                                <div class="col-4">
                                    <strong>
                                        <u>VÍA DE EMBARQUE:</u>
                                    </strong>
                                    <br />
                                    <span t-field="o.way_of_shipment_id" />
                                </div>
                                <div class="col-4">
                                    <strong>
                                        <u>ORDEN DE COMPRA:</u>
                                    </strong>
                                    <br />
                                    <span t-field="o.note" />
                                </div>
                                <div class="col-4">
                                    <strong>
                                        <u>TONELADAS TOTALES:</u>
                                    </strong>
                                    <br />
                                    <span t-esc="'%.2f' % sum(o.move_ids.mapped('tons_display'))" />
                                </div>
                            </div>
                        </div>
                        <div class="mt-4">
                            <table class="table table-bordered w-100">
                                <thead>
                                    <tr style="text-align: center;">
                                        <th style="padding: 8px;">PRODUCTO</th>
                                        <th style="width: 20%; padding: 8px;">CANT.</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="o.move_ids" t-as="line">
                                        <tr>
                                            <td class="text-start" style="padding: 5px 10px;">
                                                <span t-field="line.product_id" />
                                            </td>
                                            <td class="text-center" style="padding: 5px;">
                                                <span t-field="line.quantity"
                                                    t-options='{"widget": "integer"}' />
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </div>
                        <div style="margin-top: 100px;" class="text-center">
                            <strong>___________________________</strong>
                            <p class="mt-2" style="font-weight: bold;">FIRMA DEL CLIENTE</p>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>

    <record id="action_report_delivery_remision" model="ir.actions.report">
        <field name="name">REMISIÓN</field>
        <field name="model">stock.picking</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">real.report_delivery_remision_document</field>
        <field name="report_file">real.report_delivery_remision_document</field>
        <field name="binding_model_id" ref="stock.model_stock_picking" />
        <field name="binding_type">report</field>
        <field name="print_report_name">'REMISIÓN - ' + object.name</field>
    </record>
</odoo>